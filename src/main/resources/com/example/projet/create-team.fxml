<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #E3E8EA;" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.projet.CreateTeamController">

    <top>
        <VBox alignment="CENTER_LEFT" style="-fx-background-color: #3B4CCA; -fx-padding: 15 20 15 20;">
            <Label text="Pokémon Showdown - Teambuilder" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="22.0"/>
                </font>
            </Label>
            <Label text="Format: Custom | 3 à 6 Pokémon | Max 4 attaques par Pokémon" textFill="#FFDE00">
                <font>
                    <Font name="System Bold" size="13.0"/>
                </font>
            </Label>
        </VBox>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="25.0" style="-fx-padding: 30;">

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-border-color: #C0C8CF; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                <Label text="Votre Équipe" style="-fx-text-fill: #333333;">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>
                <ListView fx:id="teamPokemonsList" prefHeight="350.0" prefWidth="200.0" style="-fx-border-color: #E0E0E0; -fx-control-inner-background: #F9F9F9;"/>
                <Button text="🗑 Retirer le Pokémon" onAction="#onRemovePokemon" maxWidth="Infinity" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8;"/>
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-border-color: #C0C8CF; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                <Label text="Pokédex" style="-fx-text-fill: #333333;">
                    <font>
                        <Font name="System Bold" size="18.0"/>
                    </font>
                </Label>
                <ListView fx:id="availablePokemonsList" prefHeight="350.0" prefWidth="200.0" style="-fx-border-color: #E0E0E0;"/>
                <Button text="➕ Ajouter à l'équipe" onAction="#onChoosePokemon" maxWidth="Infinity" style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8;"/>
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-border-color: #C0C8CF; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 3);">

                <Label text="Attaques Possibles" style="-fx-text-fill: #333333;">
                    <font>
                        <Font name="System Bold" size="16.0"/>
                    </font>
                </Label>
                <ListView fx:id="possibleAttacksList" prefHeight="135.0" prefWidth="220.0" style="-fx-border-color: #E0E0E0;"/>
                <Button text="⬇ Équiper l'attaque" onAction="#onAddAttack" maxWidth="Infinity" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6;"/>

                <Region prefHeight="15.0"/> <Label text="Attaques Équipées (4 max)" style="-fx-text-fill: #333333;">
                <font>
                    <Font name="System Bold" size="16.0"/>
                </font>
            </Label>
                <ListView fx:id="equippedAttacksList" prefHeight="135.0" prefWidth="220.0" style="-fx-border-color: #E0E0E0; -fx-control-inner-background: #F4F6F6;"/>
                <Button text="⬆ Retirer l'attaque" onAction="#onRemoveAttack" maxWidth="Infinity" style="-fx-background-color: #95A5A6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6;"/>
            </VBox>

        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="30.0" style="-fx-padding: 0 30 30 30;">
            <Button text="💾 Sauvegarder l'équipe" onAction="#onValiderEquipe" style="-fx-background-color: #F39C12; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 25; -fx-cursor: hand; -fx-background-radius: 30;"/>
            <Button text="⚔ Lancer le Combat" onAction="#onPlay" style="-fx-background-color: #3B4CCA; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12 35; -fx-cursor: hand; -fx-background-radius: 30;"/>
        </HBox>
    </bottom>

</BorderPane>